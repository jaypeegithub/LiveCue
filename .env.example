# Supabase — server (cron, API routes, DB). URL = Project URL from Supabase dashboard (no trailing slash).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase — client (login/signup). Set in Vercel for Production + Preview, then redeploy.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key

# Cron — set in Vercel; required for /api/cron/fight-status
CRON_SECRET=your_random_secret_at_least_16_chars

# Twilio — SMS/voice notifications (Account SID, Auth Token, and Twilio phone number from dashboard)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
